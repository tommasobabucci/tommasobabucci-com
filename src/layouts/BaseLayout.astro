---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description,
  ogImage = '/og-image.png',
  ogType = 'website',
} = Astro.props;

const siteUrl = 'https://tommasobabucci.com';
const pageTitle = `${title} — Tommaso Babucci`;
const canonical = `${siteUrl}${Astro.url.pathname}`;
const resolvedOg = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const isHome = Astro.url.pathname === '/';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Tommaso Babucci',
  url: siteUrl,
  jobTitle: 'AI Strategy & Development',
  worksFor: { '@type': 'Organization', name: 'Ernst & Young' },
  sameAs: ['https://www.linkedin.com/in/tommasobabucci'],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Tommaso Babucci" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph — LinkedIn, iMessage, Slack previews -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOg} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Tommaso Babucci" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOg} />

    <!-- Google Fonts: preconnect first, then stylesheet -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Krona+One&family=Sora:wght@300;400;500;600;700&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;1,6..72,400&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Person schema — homepage only -->
    {isHome && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    )}
  </head>

  <body>
    <slot />
  </body>
</html>
