---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tag: string;
  coverImage?: string;
  readingTime?: number;
}

const { title, description, date, tag, coverImage, readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={coverImage || '/og-image.png'}
>
  <article class="theme-work" style="min-height: 100vh;">
    <!-- Back link -->
    <nav class="mx-auto px-6 sm:px-8 md:px-12 pt-8" style="max-width: 700px;">
      <a
        href="/#fun-section"
        class="type-nav inline-flex items-center gap-2 transition-colors duration-250"
        style="color: #A8A29E;"
      >
        &larr; Back
      </a>
    </nav>

    <!-- Article header -->
    <header class="mx-auto px-6 sm:px-8 md:px-12 pt-12 pb-6" style="max-width: 700px;">
      <!-- Meta row: tag + date + reading time -->
      <div class="flex items-center gap-3 mb-8 flex-wrap">
        <span
          class="type-tag"
          style="color: #B53B2E; background: rgba(181,59,46,0.06); padding: 3px 10px; border-radius: 4px;"
        >
          {tag}
        </span>
        <span style="color: #D6D3D1; font-size: 10px;">&bull;</span>
        <span class="type-tag" style="color: #A8A29E;">{formattedDate}</span>
        {readingTime && (
          <>
            <span style="color: #D6D3D1; font-size: 10px;">&bull;</span>
            <span class="type-tag" style="color: #A8A29E;">{readingTime} min read</span>
          </>
        )}
      </div>

      <h1 class="article-title mb-6" style="color: #1C1917;">
        {title}
      </h1>

      <p class="article-description" style="color: #57534E;">
        {description}
      </p>

      <!-- Accent line -->
      <div class="mt-8" style="width: 32px; height: 2px; background: #B53B2E; border-radius: 1px;"></div>
    </header>

    <!-- Cover image — wider than text column -->
    {coverImage && (
      <div class="mx-auto px-6 sm:px-8 md:px-12 mt-8 mb-14" style="max-width: 920px;">
        <img
          src={coverImage}
          alt={title}
          class="w-full article-cover-image"
        />
      </div>
    )}

    <!-- Article body -->
    <div class="mx-auto px-6 sm:px-8 md:px-12 pb-16 article-prose" style="max-width: 700px;">
      <slot />
    </div>

    <!-- Footer nav -->
    <footer class="mx-auto px-6 sm:px-8 md:px-12 pb-24" style="max-width: 700px;">
      <div style="border-top: 1px solid rgba(0, 0, 0, 0.07); padding-top: 32px;">
        <a
          href="/#fun-section"
          class="inline-flex items-center gap-2 transition-colors duration-250"
          style="font-family: 'Sora', sans-serif; font-size: 13px; font-weight: 500; color: #A8A29E;"
        >
          &larr; All articles
        </a>
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .article-title {
    font-family: "Krona One", sans-serif;
    font-size: clamp(24px, 3.5vw, 36px);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.025em;
  }

  .article-description {
    font-family: "Newsreader", Georgia, serif;
    font-size: 19px;
    font-weight: 400;
    font-style: italic;
    line-height: 1.6;
    font-optical-sizing: auto;
  }

  .article-cover-image {
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  }

  footer a:hover {
    color: #B53B2E !important;
  }

  nav a:hover {
    color: #B53B2E !important;
  }

  @media (max-width: 640px) {
    .article-description {
      font-size: 17px;
    }
  }
</style>
