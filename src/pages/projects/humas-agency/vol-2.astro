---
import ComicLayout from '../../../layouts/ComicLayout.astro';
import ComicFrame from '../../../components/comic/ComicFrame.astro';
import FadeIn from '../../../components/FadeIn.astro';
import frames from '../../../data/humas-agency/vol2-script.json';

// Build image path from frame number
function frameSrc(num: number): string {
  return `/images/projects/humas-agency/vol-2/frame-${String(num).padStart(2, '0')}.png`;
}

// Map layout values to CSS class names
function layoutName(layout: string): string {
  const map: Record<string, string> = {
    'featured': 'featured',
    'standard': 'featured',
    'text-left': 'text-left',
    'text-right': 'text-right',
    'text-overlay': 'text-overlay',
    'text-below': 'text-below',
  };
  return map[layout] || 'featured';
}
---

<ComicLayout
  title="The Blackout — Huma's Agency Vol. 2"
  description="Volume 2 of Huma's Agency: The system optimizes itself. Huma goes back to where it all started."
  volumeLabel="Vol. 2"
  ogImage="/images/projects/humas-agency/vol-2-cover.png"
>
  <!-- ============================================================
       COVER — Full viewport opening
       ============================================================ -->
  <section class="comic-cover">
    <div class="comic-cover-bg">
      <img
        src="/images/projects/humas-agency/vol-2-cover.png"
        alt="Huma stands before frozen screens on Floor 27 as the system enters deep optimization"
        class="comic-cover-img"
      />
      <div class="comic-cover-overlay"></div>
    </div>
    <div class="comic-cover-content">
      <span class="comic-cover-label">Volume 2</span>
      <h1 class="comic-cover-title">The Blackout</h1>
      <span class="comic-cover-series">Huma's Agency</span>
      <div class="comic-cover-scroll">
        <span>Scroll to begin</span>
        <span class="comic-cover-arrow">&darr;</span>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FRAMES — 34 scenes
       ============================================================ -->
  {frames.map((frame: any, i: number) => (
    <ComicFrame
      number={frame.number}
      imageSrc={frameSrc(frame.number)}
      imageAlt={frame.imageAlt}
      readerText={frame.readerText}
      layout={layoutName(frame.displayNotes?.layout || 'featured')}
      dialogueSpeaker={frame.dialogueSpeaker}
      dialogueText={frame.dialogueText}
      isEager={i < 3}
    />
  ))}

  <!-- ============================================================
       ENDING
       ============================================================ -->
  <section class="comic-ending">
    <FadeIn direction="scale">
      <div class="comic-ending-inner">
        <span class="comic-ending-dots">&middot;&ensp;&middot;&ensp;&middot;</span>
        <h2 class="comic-ending-title">End of Volume 2</h2>
        <div class="comic-ending-line"></div>
        <div class="comic-ending-nav">
          <a href="/projects/humas-agency/" class="comic-ending-link">
            &larr; Huma's Agency
          </a>
          <span class="comic-ending-next">Volume 3: The Override — Coming Soon</span>
        </div>
      </div>
    </FadeIn>
  </section>
</ComicLayout>
