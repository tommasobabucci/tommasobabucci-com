---
import FadeIn from '../FadeIn.astro';

interface Props {
  act: string;
}

const { act } = Astro.props;

const actLabels: Record<string, string> = {
  prologue: 'Prologue',
  act1: 'Act I',
  act2: 'Act II',
  act3: 'Act III',
  act4: 'Act IV',
  coda: 'Coda',
};

const label = actLabels[act] || act;
---

<FadeIn direction="scale">
  <div class="comic-act-divider">
    <span class="comic-act-dots">&middot;&ensp;&middot;&ensp;&middot;</span>
    <span class="comic-act-label">{label}</span>
  </div>
</FadeIn>
