---
interface Props {
  class?: string;
  delay?: number;
  tag?: string;
  direction?: 'up' | 'left' | 'right' | 'scale';
}

const { class: className = '', delay, tag = 'div', direction = 'up' } = Astro.props;
const Tag = tag as any;
const style = delay ? `transition-delay: ${delay}s;` : undefined;

const directionClass = {
  up: 'fade-in',
  left: 'fade-in-left',
  right: 'fade-in-right',
  scale: 'fade-in-scale',
}[direction];
---

<Tag class={`${directionClass} ${className}`} style={style}>
  <slot />
</Tag>

<script is:inline>
  if (!document.documentElement.dataset.fadeInit) {
    document.documentElement.dataset.fadeInit = '1';
    function initFadeObserver() {
      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll('.fade-in, .fade-in-left, .fade-in-right, .fade-in-scale').forEach(function (el) {
        observer.observe(el);
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFadeObserver);
    } else {
      initFadeObserver();
    }
  }
</script>
